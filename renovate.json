{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "customManagers:dockerfileVersions",
        "github>juancarlosjr97/one-renovate-configuration-to-rule-them-all#main",
        "github>juancarlosjr97/one-renovate-configuration-to-rule-them-all//presets/internal-tooling-circular#main"
    ],
    "packageRules": [
        {
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "docker.io/library/node"
            ],
            "versionCompatibility": "^(?<version>[^-]+)(?<compatibility>-alpine3.23)?$",
            "versioning": "node"
        },
        {
            "description": "Pin actions/checkout to v5 until container actions support v6 credential storage",
            "matchPackageNames": [
                "actions/checkout"
            ],
            "allowedVersions": "<6.0.0"
        }
    ]
}
