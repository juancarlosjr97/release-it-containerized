{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "customManagers:dockerfileVersions",
        "github>juancarlosjr97/renovate-configuration#main",
        "github>juancarlosjr97/renovate-configuration//presets/internal-tooling-circular#main"
    ],
    "packageRules": [
        {
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "docker.io/library/node"
            ],
            "versionCompatibility": "^(?<version>[^-]+)(?<compatibility>-alpine3.23)?$",
            "versioning": "node"
        },
        {
            "description": "Pin actions/checkout to v5 until container actions support v6 credential storage",
            "matchPackageNames": [
                "actions/checkout"
            ],
            "allowedVersions": "<6.0.0"
        },
        {
            "description": "Internal shared-tooling repositories are always referenced via the main branch and must not be updated by Renovate. See: juancarlosjr97/pre-commit-to-rule-them-all, juancarlosjr97/github-actions-workflows-to-rule-them-all, juancarlosjr97/release-it-containerized, juancarlosjr97/renovate-configuration.",
            "matchPackageNames": [
                "juancarlosjr97/github-actions-workflows-to-rule-them-all",
                "juancarlosjr97/pre-commit-to-rule-them-all",
                "juancarlosjr97/release-it-containerized",
                "juancarlosjr97/renovate-configuration"
            ],
            "enabled": false
        }
    ]
}
